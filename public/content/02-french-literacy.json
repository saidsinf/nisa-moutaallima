    },
    "sounds": [
      { "combo": "ou", "sound_ar": "او", "example": "jour (يوم), loup (ذئب), soupe (حساء)", "audio_text": "ou comme dans jour" },
      { "combo": "on / om", "sound_ar": "ون (من الأنف)", "example": "bon (جيد), maison (بيت), nom (اسم)", "audio_text": "on comme dans bon" },
      { "combo": "an / am / en / em", "sound_ar": "ان (من الأنف)", "example": "enfant (طفل), dans (في), temps (وقت)", "audio_text": "an comme dans enfant" },
      { "combo": "in / im / ain / ein", "sound_ar": "إن (من الأنف)", "example": "main (يد), pain (خبز), bien (جيد)", "audio_text": "in comme dans main" },
      { "combo": "oi", "sound_ar": "وا", "example": "moi (أنا), toi (أنت), boire (شرب)", "audio_text": "oi comme dans moi" },
      { "combo": "au / eau", "sound_ar": "أو", "example": "eau (ماء), beau (جميل), gâteau (كعكة)", "audio_text": "eau comme dans eau" },
      { "combo": "ai / ei", "sound_ar": "إ", "example": "maison (بيت), neige (ثلج), lait (حليب)", "audio_text": "ai comme dans maison" },
      { "combo": "ch", "sound_ar": "ش", "example": "chat (قط), chaud (ساخن), chercher (بحث)", "audio_text": "ch comme dans chat" },
      { "combo": "ph", "sound_ar": "ف", "example": "pharmacie (صيدلية), photo (صورة), téléphone", "audio_text": "ph comme dans pharmacie" },
      { "combo": "gn", "sound_ar": "نيْ", "example": "montagne (جبل), ligne (خط), signe (علامة)", "audio_text": "gn comme dans montagne" },
      { "combo": "gu", "sound_ar": "ڭ", "example": "guerre (حرب), guide (دليل), guitare", "audio_text": "gu comme dans guide" },
      { "combo": "qu", "sound_ar": "ك", "example": "quatre (4), qui (من), quand (متى)", "audio_text": "qu comme dans quatre" },
      { "combo": "tion", "sound_ar": "سْيون", "example": "station, nation, attention", "audio_text": "tion comme dans attention" },
      { "combo": "ille", "sound_ar": "إي", "example": "fille (بنت), famille (عائلة), vanille", "audio_text": "ille comme dans fille" }
    ]
